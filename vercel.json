{
  "env": {
    "ENABLE_EXPERIMENTAL_COREPACK": "1"
  },
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @workspace/devlink-ke run build && pnpm --filter @workspace/api-server run build",
  "outputDirectory": "artifacts/devlink-ke/dist/public",
  "framework": null,
  "functions": {
    "artifacts/api-server/dist/index.mjs": {
      "runtime": "nodejs24.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/artifacts/api-server/dist/index.mjs"
    }
  ]
}
