{
  "env": {
    "ENABLE_EXPERIMENTAL_COREPACK": "1"
  },
  "builds": [
    {
      "src": "artifacts/devlink-ke/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist/public",
        "buildCommand": "cd ../.. && pnpm install && pnpm --filter @workspace/devlink-ke run build"
      }
    },
    {
      "src": "artifacts/api-server/src/index.ts",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["artifacts/api-server/src/**", "lib/**"]
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "artifacts/api-server/src/index.ts" },
    { "src": "/(.*)", "dest": "artifacts/devlink-ke/package.json" }
  ]
}
