# ── DevLink KE — Environment Variables ────────────────────────────────────
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/devlink_ke

# ── Session ───────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string

# ── Node ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# ── Google OAuth ──────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI to match GOOGLE_CALLBACK_URL below
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://devlink.erunstech.top/api/auth/google/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers → New OAuth App
# 2. Set callback URL to match GITHUB_CALLBACK_URL below
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://devlink.erunstech.top/api/auth/github/callback

# ── Frontend URL (for OAuth redirects) ────────────────────────────────────
FRONTEND_URL=https://devlink.erunstech.top

# ── Uploads (avatars, etc.) ───────────────────────────────────────────────
# Defaults to ./uploads relative to the project root if not set.
# In production with systemd, set this to a persistent path:
#   UPLOADS_DIR=/var/www/devlink/uploads
UPLOADS_DIR=

# ── Email (optional — Resend) ─────────────────────────────────────────────
# Only needed if you want email verification / password reset emails.
# Get an API key at https://resend.com
RESEND_API_KEY=
