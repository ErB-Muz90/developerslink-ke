# ── Server ──────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon, Supabase, or your own)
DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# ── Session ─────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SESSION_SECRET=replace-with-a-random-64-character-hex-string

# ── Logging ─────────────────────────────────────────────────────────────
LOG_LEVEL=info

# ── Google OAuth ────────────────────────────────────────────────────────
# 1. Go to https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI to match GOOGLE_CALLBACK_URL below
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=https://devlink.erunstech.top/api/auth/google/callback

# ── GitHub OAuth ────────────────────────────────────────────────────────
# 1. Go to https://github.com/settings/developers → New OAuth App
# 2. Set callback URL to match GITHUB_CALLBACK_URL below
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret
GITHUB_CALLBACK_URL=https://devlink.erunstech.top/api/auth/github/callback

# ── Frontend URL (for OAuth redirects) ────────────────────────────────────
FRONTEND_URL=https://devlink.erunstech.top

# ── Uploads ─────────────────────────────────────────────────────────────
UPLOADS_DIR=./uploads
